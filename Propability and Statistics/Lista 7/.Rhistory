# --- DANE ---
wyniki <- c(1, 2, 3, 4, 5, 6)
frekwencja <- c(171, 200, 168, 213, 226, 222)
n <- sum(frekwencja)
# Jeśli kostka jest symetryczna, p = 1/6 dla każdej ściany.
oczekiwane <- rep(n / 6, 6)
print(data.frame(Wynik=wyniki, Obserwowane=frekwencja, Oczekiwane=oczekiwane))
# --- DANE ---
wyniki <- c(1, 2, 3, 4, 5, 6)
frekwencja <- c(171, 200, 168, 213, 226, 222)
n <- sum(frekwencja)
# Jeśli kostka jest symetryczna, p = 1/6 dla każdej ściany.
oczekiwane <- rep(n / 6, 6)
print(data.frame(Wynik=wyniki, Obserwowane=frekwencja, Oczekiwane=oczekiwane))
chi_sq_stat <- sum((frekwencja - oczekiwane)^2 / oczekiwane)
cat("Wartość statystyki Chi-kwadrat:", chi_sq_stat, "\n")
# Stopnie swobody df = k - 1 = 6 - 1 = 5
p_val <- 1 - pchisq(chi_sq_stat, df=5)
cat("Wartość p:", p_val, "\n")
test_chi <- chisq.test(frekwencja)
print(test_chi)
mieszkania <- read.csv("mieszkania.csv", sep=";", dec=".")
mieszkania$cena_m2 <- mieszkania$cena / mieszkania$metraz
mieszkania.head
mieszkania.head()
head(mieszkania)
mieszkania$Cena_m2 <- mieszkania$Cena / mieszkania$Metraz
head(mieszkania)
# a) Test Shapiro-Wilka dla ceny za m2
shapiro_cena <- shapiro.test(mieszkania$Cena_m2)
print(shapiro_cena)
# b) Test Shapiro-Wilka dla metrażu
shapiro_metraz <- shapiro.test(mieszkania$Metraz)
print(shapiro_metraz)

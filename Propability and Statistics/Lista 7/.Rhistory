lines(czas_seq, masa_pred_smooth, col="red", lwd=2)
legend("topleft", legend=c("Dane", "Model wykładniczy"),
col=c("blue", "red"), pch=c(19, NA), lty=c(NA, 1), lwd=c(NA,2))

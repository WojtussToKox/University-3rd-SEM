prob_p2 <- 1 - ppois(3, lambda = lambda)
prob_p2
# 3. P(3 <= X <= 5) => P(X <= 5) - P(X <= 2)
prob_p3 <- ppois(5, lambda = lambda) - ppois(2, lambda = lambda)
prob_p3

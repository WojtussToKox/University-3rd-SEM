y_pois <- dpois(x_pois, lambda = lambda)
plot(x_pois, y_pois, type = "h", lwd = 2, col = "red",
main = "Sprzedaż samochodów (Poisson lambda=6)",
xlab = "Liczba samochodów", ylab = "Prawdopodobieństwo")

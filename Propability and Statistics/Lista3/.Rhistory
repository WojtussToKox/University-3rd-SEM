# Parametry rozkładu
n <- 6
p <- 0.5
# 1. P(X = 5) - dokładnie 5 reszek [cite: 19]
prob_1a <- dbinom(5, n, p)
cat("Zad 1a: P(X = 5) =", prob_1a, "\n")
# 2. P(X >= 3) - co najmniej 3 reszki [cite: 20]
# P(X >= 3) = 1 - P(X <= 2)
prob_1b <- 1 - pbinom(2, n, p)
cat("Zad 1b: P(X >= 3) =", prob_1b, "\n")
# 3. P(2 <= X <= 4) - między 2 a 4 reszki [cite: 21]
# P(2 <= X <= 4) = P(X <= 4) - P(X <= 1)  <- Zgodnie z wzorem z instrukcji [cite: 9, 10]
prob_1c <- pbinom(4, n, p) - pbinom(1, n, p)
cat("Zad 1c: P(2 <= X <= 4) =", prob_1c, "\n")
# 4. Wykres rozkładu zmiennej X [cite: 22]
x_val <- 0:6
y_val <- dbinom(x_val, n, p)
plot(x_val, y_val, type="h", lwd=3, col="blue",
main="Rozkład dwumianowy (n=6, p=0.5)", xlab="Liczba reszek", ylab="Prawdopodobieństwo")
points(x_val, y_val, pch=19, col="blue")
# 2. P(X >= 3)
# P(X >= 3) = 1 - P(X <= 2)
prob_1b <- 1 - pbinom(2, n, p)
# 2. P(X >= 3)
# P(X >= 3) = 1 - P(X <= 2)
prob_1b <- 1 - pbinom(2, n, p)
prob_1b
prob_1c

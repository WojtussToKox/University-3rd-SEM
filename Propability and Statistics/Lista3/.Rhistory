# Parametry rozkładu
n <- 6
p <- 0.5
# 1. P(X = 5)
prob_1a <- dbinom(5, n, p)
prob_1a
# 2. P(X >= 3)
# P(X >= 3) = 1 - P(X <= 2)
prob_1b <- 1 - pbinom(2, n, p)
prob_1b
# 3. P(2 <= X <= 4)
# P(2 <= X <= 4) = P(X <= 4) - P(X <= 1)
prob_1c <- pbinom(4, n, p) - pbinom(1, n, p)
prob_1c
?plot
x_val <- 0:6
y_val <- dbinom(x_val, n, p)
plot(x_val, y_val, type="h", lwd=3, col="blue",
main="Rozkład dwumianowy (n=6, p=0.5)", xlab="Liczba reszek", ylab="Prawdopodobieństwo")
points(x_val, y_val, pch=40, col="blue")
points(x_val, y_val, pch=19, col="blue")
plot(x_val, y_val, type="h", lwd=3, col="blue",
main="Rozkład dwumianowy (n=6, p=0.5)", xlab="Liczba reszek", ylab="Prawdopodobieństwo")
# Parametr lambda dla 2 tygodni 2 tyg x 3 tygodniowo
lambda <- 6
# 1. P(X = 5)
prob_2a <- dpois(5, lambda)
prob_2a
# 2. P(X >= 4)
# P(X >= 4) = 1 - P(X <= 3)
prob_2b <- 1 - ppois(3, lambda)
prob_2b
# 3. P(3 <= X <= 5)
# P(3 <= X <= 5) = P(X <= 5) - P(X <= 2)
prob_2c <- ppois(5, lambda) - ppois(2, lambda)
prob_2c
# 4. Wykres dla 0 <= x <= 30
x_pois <- 0:30
y_pois <- dpois(x_pois, lambda)
plot(x_pois, y_pois, type="h", lwd=2, col="red",
main="Rozkład Poissona (lambda=6)", xlab="Liczba samochodów", ylab="Prawdopodobieństwo")
# Parametry
n <- 6
p <- 0.5
# 1. P(X = 5) - Prawdopodobieństwo punktowe
prob_1 <- dbinom(5, size = n, prob = p)
print(paste("P(X = 5):", prob_1))
# 2. P(X >= 3)
# W R pbinom liczy P(X <= k), więc P(X >= 3) to 1 - P(X <= 2)
prob_2 <- 1 - pbinom(2, size = n, prob = p)
print(paste("P(X >= 3):", prob_2))
# 3. P(2 <= X <= 4)
# To jest P(X <= 4) - P(X <= 1)
prob_3 <- pbinom(4, size = n, prob = p) - pbinom(1, size = n, prob = p)
print(paste("P(2 <= X <= 4):", prob_3))
# 4. Wykres rozkładu (typ "h" - histogram liniowy/szpilkowy)
x_vals <- 0:n
y_vals <- dbinom(x_vals, size = n, prob = p)
plot(x_vals, y_vals, type = "h", lwd = 5, col = "blue",
main = "Rozkład liczby reszek w 6 rzutach",
xlab = "Liczba reszek", ylab = "Prawdopodobieństwo")
# Parametry
mu <- 170
sigma <- sqrt(144) # czyli 12
# 1. P(X > 180) => 1 - P(X <= 180)
prob_n1 <- 1 - pnorm(180, mean = mu, sd = sigma)
print(paste("P(X > 180):", prob_n1))
# 2. P(X < 165)
prob_n2 <- pnorm(165, mean = mu, sd = sigma)
print(paste("P(X < 165):", prob_n2))
# 3. P(155 < X < 190)
prob_n3 <- pnorm(190, mean = mu, sd = sigma) - pnorm(155, mean = mu, sd = sigma)
print(paste("P(155 < X < 190):", prob_n3))
# 4. Wzrost k, taki że 10% jest wyższych
# P(X > k) = 0.10 => P(X <= k) = 0.90
k_wzrost <- qnorm(0.90, mean = mu, sd = sigma)
print(paste("Wzrost k (top 10%):", k_wzrost))
# Parametry
lambda_exp <- 4
# 1. P(T > 30s) => P(T > 0.5 min) => 1 - P(T <= 0.5)
prob_e1 <- 1 - pexp(0.5, rate = lambda_exp)
print(paste("P(T > 30s):", prob_e1))
# 2. P(T < 20s) => P(T < 1/3 min)
prob_e2 <- pexp(1/3, rate = lambda_exp)
print(paste("P(T < 20s):", prob_e2))
# 3. P(40s < T < 80s) => P(2/3 < T < 4/3)
prob_e3 <- pexp(4/3, rate = lambda_exp) - pexp(2/3, rate = lambda_exp)
print(paste("P(40s < T < 80s):", prob_e3))
# 4. Czas t taki, że P(czas > t) = 0.2
# 1 - P(czas <= t) = 0.2  =>  P(czas <= t) = 0.8
t_szukane <- qexp(0.8, rate = lambda_exp)
print(paste("Szukany czas t (w min):", t_szukane))
# 5. Wykres gęstości [0, 3]
# Tworzymy sekwencję punktów co 0.01
t_vals <- seq(0, 3, by=0.01)
density_vals <- dexp(t_vals, rate = lambda_exp)
plot(t_vals, density_vals, type="l", col="green", lwd=2,
main="Gęstość czasu między telefonami",
xlab="Czas (min)", ylab="Gęstość f(t)")
# Parametry
a <- 4
b <- 12
# 1. P(X < 7)
# Dla zmiennych ciągłych P(X < k) to to samo co P(X <= k)
prob_u1 <- punif(7, min = a, max = b)
print(paste("P(X < 7):", prob_u1))
# 2. P(5 < X < 11) => P(X < 11) - P(X < 5)
prob_u2 <- punif(11, min = a, max = b) - punif(5, min = a, max = b)
print(paste("P(5 < X < 11):", prob_u2))
# 3. P(X > 10) => 1 - P(X < 10)
prob_u3 <- 1 - punif(10, min = a, max = b)
print(paste("P(X > 10):", prob_u3))
# 4. Znajdź x taki, że P(X > x) = 0.6
# P(X > x) = 0.6  =>  1 - P(X <= x) = 0.6  =>  P(X <= x) = 0.4
# Musimy znaleźć kwantyl rzędu 0.4
x_szukane <- qunif(0.4, min = a, max = b)
print(paste("Szukane x:", x_szukane))
# Parametry
mu <- 170
sigma <- sqrt(144) # czyli 12
# 1. P(X > 180) => 1 - P(X <= 180)
prob_n1 <- 1 - pnorm(180, mean = mu, sd = sigma)
print(paste("P(X > 180):", prob_n1))
# 2. P(X < 165)
prob_n2 <- pnorm(165, mean = mu, sd = sigma)
print(paste("P(X < 165):", prob_n2))
# 3. P(155 < X < 190)
prob_n3 <- pnorm(190, mean = mu, sd = sigma) - pnorm(155, mean = mu, sd = sigma)
print(paste("P(155 < X < 190):", prob_n3))
# 4. Wzrost k, taki że 10% jest wyższych
# P(X > k) = 0.10 => P(X <= k) = 0.90
k_wzrost <- qnorm(0.90, mean = mu, sd = sigma)
print(paste("Wzrost k (top 10%):", k_wzrost))
# Parametry
n_k <- 180
p_k <- 1/6
# 1. P(X = 27)
prob_k1 <- dbinom(27, size = n_k, prob = p_k)
print(paste("P(X = 27):", prob_k1))
# 2. P(X >= 32) => 1 - P(X <= 31)
prob_k2 <- 1 - pbinom(31, size = n_k, prob = p_k)
print(paste("P(X >= 32):", prob_k2))
# 3. P(X < 29) => P(X <= 28) (bo to zmienna dyskretna!)
prob_k3 <- pbinom(28, size = n_k, prob = p_k)
print(paste("P(X < 29):", prob_k3))
# 4. P(25 <= X <= 33) => P(X <= 33) - P(X <= 24)
prob_k4 <- pbinom(33, size = n_k, prob = p_k) - pbinom(24, size = n_k, prob = p_k)
print(paste("P(25 <= X <= 33):", prob_k4))
print(paste("P(X > 180):", prob_n1))
k_wzrost

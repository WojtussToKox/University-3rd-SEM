# 2. Obliczanie odchylenia standardowego dla ceny w każdej dzielnicy (listy)
odchylenia_sd <- sapply(listy_dzielnic, function(x) sd(x$Cena, na.rm = TRUE))
# 3. Tworzenie ramki wyników
wyniki_stabilnosci <- data.frame(
Dzielnica = names(odchylenia_sd),
odchylenie_standardowe_cen = as.numeric(odchylenia_sd)
)
# 4. Sortowanie wyników
wyniki_stabilnosci <- wyniki_stabilnosci[order(wyniki_stabilnosci$odchylenie_standardowe_cen), ]
cat("j) ** Stabilność i zróżnicowanie cen w dzielnicach (Odchylenie Standardowe):\n")
print(wyniki_stabilnosci)
